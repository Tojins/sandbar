{
  "name": "@offergeist/sandbar",
  "version": "0.6.4",
  "description": "Self-hosted issue-tracker-driven coding agent orchestrator.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "prompts/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "prepare": "npm run build",
    "preversion": "npm run check && npm test",
    "postversion": "git push --follow-tags"
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.5"
  }
}
